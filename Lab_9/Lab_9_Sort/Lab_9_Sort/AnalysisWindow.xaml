<Window x:Class="Lab_9_Sort.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализ производительности" Height="500" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="Назад" Width="80" Height="30" HorizontalAlignment="Left" 
                Click="BtnBack_Click" Margin="0,0,0,10"/>

        <DataGrid x:Name="DgResults" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" Margin="0,0,0,10" 
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Количество элементов" Binding="{Binding Size}" Width="150"/>
                <DataGridTextColumn Header="IntroSort" Binding="{Binding IntroSort}" Width="250"/>
                <DataGridTextColumn Header="PigeonholeSort" Binding="{Binding Pigeonhole}" Width="250"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="Анализ:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtAnalysis" Grid.Row="2" Margin="0,20,0,10" IsReadOnly="True" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="100"/>

        <Button Content="Начать анализ" Grid.Row="3" Width="120" Height="30" 
                HorizontalAlignment="Right" Background="LightGreen" Click="BtnAnalyze_Click"/>
    </Grid>
</Window>