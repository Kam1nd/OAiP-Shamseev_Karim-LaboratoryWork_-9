<Window x:Class="Lab_9_Sort.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сортировка массивов" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
            <StackPanel>
                <GroupBox Header="Сгенерировать массив:" Margin="0,0,0,10">
                    <StackPanel>
                        <Slider x:Name="SliderSize" Minimum="2" Maximum="200" Value="50" 
                                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,5"
                                ValueChanged="SliderSize_ValueChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Количество элементов массива:" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtSize" Text="50" Width="50" Margin="5,0,0,0" 
             TextChanged="TxtSize_TextChanged" 
             ToolTipService.InitialShowDelay="0" />
                        </StackPanel>
                        <Button Content="Сгенерировать массив"  x:Name="BtnGenerate" Click="BtnGenerate_Click" Margin="0,5"/>
                        <Button Content="Массив из файла" Click="BtnLoad_Click" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Методы сортировки" Margin="0,0,0,10">
                    <StackPanel>
                        <RadioButton x:Name="RbIntro" Content="IntroSort" IsChecked="True" Margin="0,3"/>
                        <RadioButton x:Name="RbPigeon" Content="PigeonholeSort" Margin="0,3"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Результат сортировки" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="TxtComp" Text="Количество сравнений: 0" Margin="0,2"/>
                        <TextBlock x:Name="TxtPerm" Text="Количество перестановок: 0" Margin="0,2"/>
                        <TextBlock x:Name="TxtTime" Text="Время сортировки: 0 мс" Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

                <Button Content="Начать сортировку" Click="BtnSort_Click" Background="LightGreen" 
                        Height="40" Margin="0,5" FontWeight="Bold"/>
                <Button Content="Очистить значения" Click="BtnClear_Click" Background="Tomato" 
                        Height="30" Margin="0,5"/>
                <Button Content="Сохранить в файл" Click="BtnSave_Click" Background="DodgerBlue" 
                        Foreground="White" Height="30" Margin="0,5"/>
                <Button Content="Анализ методов сортировки" Click="BtnAnalysis_Click" 
                        Background="Orange" Height="30" Margin="0,5"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Исходный массив:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtArray" Grid.Row="1" IsReadOnly="True" Margin="0,0,0,10" 
                     TextWrapping="Wrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" 
                     MaxHeight="100"/>

            <TextBlock x:Name="TxtStepTitle" Text="Сортировка (по убыванию):" FontWeight="Bold" 
                       Grid.Row="2" Margin="0,0,0,5"/>
            <RichTextBox x:Name="RtbSteps" Grid.Row="2" Margin="0,20,0,0" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"/>

            <TextBlock Text="Отсортированный массив (по убыванию):" FontWeight="Bold" 
                       Grid.Row="3" Margin="0,5,0,0"/>
            <TextBox x:Name="TxtResult" Grid.Row="3" Margin="0,25,0,0" IsReadOnly="True" 
                     TextWrapping="Wrap" FontFamily="Consolas"/>
        </Grid>
    </Grid>
</Window>